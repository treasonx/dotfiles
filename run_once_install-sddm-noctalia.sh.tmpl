#!/usr/bin/env bash
# Install and configure SDDM (Simple Desktop Display Manager) with the Noctalia
# greeter theme. Safe-swaps from GDM — display-manager change takes effect on
# next reboot, and the greeter is validated in --test-mode before we touch the
# systemd DM symlink.
#
# run_once_ → chezmoi runs this exactly once per hash. To force re-run, bump:
# v2 2026-04-21 relax greeter validation (exit code → log content heuristic)
# v1 2026-04-21 initial install
# -----------------------------------------------------------------------------

set -euo pipefail

SOURCE_DIR="{{ .chezmoi.sourceDir }}"
THEME_SRC="${SOURCE_DIR}/sddm-theme-noctalia"
SDDM_CONF_SRC="${SOURCE_DIR}/etc/sddm.conf.d/10-noctalia.conf"

THEME_DST="/usr/share/sddm/themes/noctalia"
SHARED_DIR="/var/lib/sddm-noctalia"
SHARED_THEME_CONF="${SHARED_DIR}/theme.conf"
SHARED_BG="${SHARED_DIR}/background.png"

log() { printf '\e[1;34m==> %s\e[0m\n' "$*"; }
warn() { printf '\e[1;33m!!  %s\e[0m\n' "$*" >&2; }
err() { printf '\e[1;31mxx  %s\e[0m\n' "$*" >&2; exit 1; }

[[ -d "$THEME_SRC" ]] || err "Theme source missing: $THEME_SRC"
[[ -f "$SDDM_CONF_SRC" ]] || err "SDDM config missing: $SDDM_CONF_SRC"

# -----------------------------------------------------------------------------
# 1. Install SDDM + Qt6 deps (idempotent; dnf skips installed packages)
# -----------------------------------------------------------------------------
log "Installing SDDM + Qt6 dependencies"
sudo dnf install -y sddm qt6-qt5compat qt6-qtdeclarative qt6-qtwayland

# -----------------------------------------------------------------------------
# 2. Create shared dir (james writes theme.conf + background, sddm reads)
# -----------------------------------------------------------------------------
log "Creating ${SHARED_DIR} (james:sddm 0750)"
sudo install -d -o "$USER" -g sddm -m 0750 "$SHARED_DIR"

# -----------------------------------------------------------------------------
# 3. Deploy theme files to /usr/share/sddm/themes/noctalia
# -----------------------------------------------------------------------------
log "Deploying theme to ${THEME_DST}"
sudo rsync -a --delete \
  --exclude=".source" \
  --exclude="theme.conf.default" \
  "${THEME_SRC}/" "${THEME_DST}/"

# Bootstrap /var/lib/sddm-noctalia/theme.conf from the shipped default so the
# greeter renders sensibly on the very first boot, before Noctalia has had a
# chance to re-render its user-template output. User (james) owns the file.
if [[ ! -f "$SHARED_THEME_CONF" ]]; then
    log "Seeding ${SHARED_THEME_CONF} from theme default"
    install -m 0644 "${THEME_SRC}/theme.conf.default" "$SHARED_THEME_CONF"
fi

# Seed a fallback background by copying the theme's bundled one.
if [[ ! -f "$SHARED_BG" ]]; then
    log "Seeding ${SHARED_BG} from bundled theme asset"
    install -m 0644 "${THEME_SRC}/Assets/background.png" "$SHARED_BG"
fi

# -----------------------------------------------------------------------------
# 4. Replace the theme's theme.conf + Assets/background.png with symlinks
#    that point into /var/lib/sddm-noctalia/. The theme source stays immutable
#    in /usr/share; only the symlink targets change at runtime.
# -----------------------------------------------------------------------------
link_once() {
    local link="$1" target="$2"
    if [[ -L "$link" ]] && [[ "$(readlink "$link")" == "$target" ]]; then
        return 0
    fi
    log "Linking ${link} -> ${target}"
    sudo ln -sfn "$target" "$link"
}

link_once "${THEME_DST}/theme.conf" "$SHARED_THEME_CONF"
link_once "${THEME_DST}/Assets/background.png" "$SHARED_BG"

# -----------------------------------------------------------------------------
# 5. Install /etc/sddm.conf.d/10-noctalia.conf
# -----------------------------------------------------------------------------
log "Installing SDDM config snippet"
sudo install -D -m 0644 "$SDDM_CONF_SRC" /etc/sddm.conf.d/10-noctalia.conf

# -----------------------------------------------------------------------------
# 6. Run sync_sddm_wallpaper once to seed the live wallpaper (non-fatal if
#    Noctalia hasn't written wallpapers.json yet — the bootstrap background is
#    already in place).
# -----------------------------------------------------------------------------
if command -v sync_sddm_wallpaper >/dev/null; then
    log "Seeding ${SHARED_BG} from Noctalia's current wallpaper (best-effort)"
    sync_sddm_wallpaper || warn "sync_sddm_wallpaper failed (non-fatal, using bootstrap asset)"
fi

# -----------------------------------------------------------------------------
# 7. Greeter validation — MANDATORY. Don't swap DMs if this fails.
#    sddm-greeter-qt6 in --test-mode opens a window; timeout closes it after 3s.
#    We judge success by LOG CONTENT, not exit code — `timeout` with SIGTERM can
#    return various codes (0, 15, 124, 143, 255) depending on how the greeter
#    handles the signal, and --test-mode always logs a harmless socket error.
# -----------------------------------------------------------------------------
log "Validating greeter in --test-mode (3s)"
set +e
timeout 3s sddm-greeter-qt6 --test-mode --theme "$THEME_DST" \
    </dev/null >/tmp/sddm-greeter-test.log 2>&1
set -e

log_contains() { grep -qiE "$1" /tmp/sddm-greeter-test.log; }
show_log() { sed 's/^/    /' /tmp/sddm-greeter-test.log >&2; }

# Positive signal: the theme's Main.qml was successfully loaded by the engine.
if ! log_contains "Loading .*$(basename "$THEME_DST")/Main\.qml"; then
    warn "Greeter did not load our Main.qml. Log:"
    show_log
    err "Aborting before display-manager swap. Fix the theme, then re-apply."
fi

# Negative signals: genuine QML failures that would break the live greeter.
if log_contains 'module .* is not installed|cannot find module|QQmlApplicationEngine failed|QML .* is not a type|file:.*error'; then
    warn "QML errors detected in greeter log:"
    show_log
    err "Aborting before display-manager swap."
fi

log "Greeter validation passed (Main.qml loaded, no QML errors)."

# -----------------------------------------------------------------------------
# 8. Swap display manager: disable gdm, enable sddm.
#    Takes effect on next reboot — do NOT restart display-manager.service live
#    (that would kill the current session).
# -----------------------------------------------------------------------------
current_dm_link="$(readlink -f /etc/systemd/system/display-manager.service 2>/dev/null || true)"
if [[ "$current_dm_link" == *"/sddm.service" ]]; then
    log "SDDM is already the active display-manager — no swap needed."
elif [[ "$current_dm_link" == *"/gdm.service" ]]; then
    log "Swapping display-manager gdm -> sddm (effective on next reboot)"
    sudo systemctl disable gdm.service
    sudo systemctl enable sddm.service
else
    warn "Unknown current display-manager: $current_dm_link"
    warn "Enabling sddm; you may need to disable the other manager manually."
    sudo systemctl enable sddm.service
fi

# -----------------------------------------------------------------------------
# Summary
# -----------------------------------------------------------------------------
cat <<SUMMARY

$(printf '\e[1;32m✔\e[0m') SDDM + Noctalia theme installed.

Next steps:
  1. Reboot to land on the new greeter:
       sudo systemctl reboot
  2. If the greeter fails to appear (black screen, Ctrl+Alt+F3):
       sddm_rollback    # one command to restore GDM
  3. Wallpaper/color sync:
       Changing your wallpaper in Noctalia will automatically refresh
       ${SHARED_DIR}/{theme.conf,background.png}. Verify with:
         ls -l ${SHARED_DIR}/

SUMMARY
