{{- /*
  Noctalia Shell settings — chezmoi template.
  Target: ~/.config/noctalia/settings.json (hot-reloaded by Noctalia).

  Only overrides live here; Noctalia fills in defaults for everything else.
  Upstream default schema: https://github.com/noctalia-dev/noctalia-shell/blob/main/Assets/settings-default.json

  Layout mirrors the retired AGS bar:
    left:   Workspace, SystemMonitor
    center: Clock, Volume, MediaMini
    right:  Tray, NotificationHistory, Battery, PowerProfile, ControlCenter, SessionMenu
*/ -}}
{
  "bar": {
    "position": "bottom",
    "monitors": [],
    "outerCorners": true,
    "showCapsule": true,
    "displayMode": "always_visible",
    "density": "default",
    "widgets": {
      "left": [
        { "id": "Workspace" },
        {
          "id": "SystemMonitor",
          "showCpuUsage": true,
          "showCpuTemp": true,
          "showMemoryUsage": true,
          "showMemoryAsPercent": true
        }
      ],
      "center": [
        { "id": "Clock", "formatHorizontal": "ddd, MMM dd  HH:mm" },
        { "id": "Volume", "displayMode": "onhover" },
        { "id": "MediaMini" }
      ],
      "right": [
        { "id": "Tray" },
        { "id": "NotificationHistory", "showUnreadBadge": true },
        { "id": "Battery", "hideIfNotDetected": true },
        { "id": "PowerProfile" },
        { "id": "ControlCenter" },
        { "id": "SessionMenu" }
      ]
    }
  },

  "general": {
    "lockOnSuspend": true,
    "compactLockScreen": false
  },

  "ui": {
    "fontDefault": "Inter",
    "fontFixed": "JetBrainsMono Nerd Font"
  },

  "colorSchemes": {
    "useWallpaperColors": false,
    "predefinedScheme": "Catppuccin",
    "darkMode": true
  },

  "wallpaper": {
    "enabled": true,
    "directory": "{{ .chezmoi.homeDir }}/Pictures/wallpapers",
    "setWallpaperOnAllMonitors": true
  },

  "notifications": {
    "enabled": true,
    "location": "top_right"
  },

  "dock": { "enabled": false },
  "nightLight": { "enabled": false }
}
