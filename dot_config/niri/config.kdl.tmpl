// niri config — parallel to dot_config/hypr/hyprland.conf.tmpl
// https://yalter.github.io/niri/Configuration:-Introduction

input {
    keyboard {
        xkb {
            layout "us"
            options "caps:escape"
        }
        repeat-delay 300
        repeat-rate 50
        numlock
    }

    {{- if eq .machine "laptop" }}
    touchpad {
        tap
        dwt
        natural-scroll
        click-method "clickfinger"
    }
    {{- end }}

    mouse {
        accel-profile "flat"
    }

    focus-follows-mouse max-scroll-amount="0%"
}

{{- if eq .machine "laptop" }}
output "eDP-2" {
    mode "2560x1600@165.000"
    scale 1.5
    position x=0 y=0
}
{{- else }}
// Desktop outputs — physical layout:
//   HDMI-A-1 (Samsung Odyssey Ark, 3840x2160) on the left.
//   DP-2 (1920x1080) and DP-3 (1920x1080) stacked on the right; the stack
//   sits ~40% down from HDMI's top edge (top of DP-2 at y=864).
output "HDMI-A-1" {
    position x=0 y=0
    // Main monitor is large — spawn new columns at half width so two
    // windows tile side-by-side by default. Other outputs keep the
    // global default (proportion 1.0).
    layout {
        default-column-width { proportion 0.5; }
    }
}
output "DP-2" {
    position x=3840 y=864
}
output "DP-3" {
    position x=3840 y=1944
}
{{- end }}

layout {
    gaps 12
    center-focused-column "on-overflow"

    preset-column-widths {
        proportion 0.5
        proportion 0.66667
        proportion 1.0
    }

    default-column-width { proportion 1.0; }

    focus-ring {
        off
    }

    border {
        off
    }

    shadow {
        on
        softness 20
        spread 3
        offset x=0 y=4
        // Match marble's --marble-shadow-color (rgba(0,0,0,0.6) == #00000099).
        color "#00000099"
    }
}

// Disable the top-left hot corner that auto-opens the overview.
// Mod+O still toggles it; this just stops the mouse-in-corner trigger.
gestures {
    hot-corners {
        off
    }
}

// Aggressive zoom-out so every window on every workspace fits on screen.
// Range 0.0–0.75, default 0.5. Lower = smaller tiles, more fit at once.
overview {
    zoom 0.25

    // Catppuccin Mocha "crust" — the palette's darkest tone, matching the AGS shell void.
    backdrop-color "#11111b"

    // Calibrated for 1080px-tall workspaces pre-zoom, so ~2× the layout.shadow values.
    workspace-shadow {
        softness 40
        spread 10
        offset x=0 y=10
        color "#00000099"
    }
}

prefer-no-csd

cursor {
    xcursor-theme "catppuccin-mocha-mauve-cursors"
    xcursor-size 24
}

environment {
    // niri-session inherits a minimal PATH from gdm-wayland-session, so
    // `spawn "ags"` and other ~/.local/bin scripts fail to exec. Prepend it.
    PATH "/home/james/.local/bin:/home/james/.cargo/bin:/usr/local/bin:/usr/bin"
    XCURSOR_THEME "catppuccin-mocha-mauve-cursors"
    XCURSOR_SIZE "24"
    HYPRCURSOR_THEME "catppuccin-mocha-mauve-cursors"
    HYPRCURSOR_SIZE "24"
    CLUTTER_BACKEND "wayland"
    GDK_BACKEND "wayland,x11"
    QT_QPA_PLATFORM "wayland;xcb"
    QT_QPA_PLATFORMTHEME "qt6ct"
    QT_WAYLAND_DISABLE_WINDOWDECORATION "1"
    XDG_CURRENT_DESKTOP "niri"
    XDG_SESSION_DESKTOP "niri"
    XDG_SESSION_TYPE "wayland"
    MOZ_ENABLE_WAYLAND "1"
    ELECTRON_OZONE_PLATFORM_HINT "auto"
    {{- if eq .machine "desktop" }}
    LIBVA_DRIVER_NAME "nvidia"
    __GLX_VENDOR_LIBRARY_NAME "nvidia"
    NVD_BACKEND "direct"
    {{- end }}
}

screenshot-path "~/Pictures/Screenshots/Screenshot from %Y-%m-%d %H-%M-%S.png"

// === Animations ===
// Window open = CRT monitor turn-on (horizontal trace unfolds vertically with
// scanlines and phosphor glow). Window close = Catppuccin Mocha dark sweep.
// Templates live in .chezmoitemplates/nirimation/ — swap include for alts:
//   crt-burn.kdl      — current (CRT open + dark burn close)
//   keyhole-burn.kdl  — SMW keyhole open + dark burn close
//   burn.kdl          — original warm-ember burn on both ends
{{ includeTemplate "nirimation/crt-burn.kdl" -}}

// === Autostart ===
// Run under niri-session so systemd user units + xdg-desktop-autostart work.
// Session-type env broadcast:
spawn-at-startup "dbus-update-activation-environment" "--systemd" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP"
spawn-at-startup "systemctl" "--user" "import-environment" "WAYLAND_DISPLAY" "XDG_CURRENT_DESKTOP"

// Polkit agent (from hyprland stack — it's just a polkit-gnome launcher)
spawn-at-startup "/home/james/.config/hypr/scripts/Polkit.sh"

// Noctalia shell (bar, notifications, lock screen, wallpaper, control center,
// session menu). Runs via the noctalia-qs Quickshell fork; config lives at
// ~/.config/noctalia/settings.json. IPC: qs -c noctalia-shell ipc call ...
spawn-at-startup "qs" "-c" "noctalia-shell"

// Network manager tray
spawn-at-startup "nm-applet" "--indicator"

// Clipboard history
spawn-sh-at-startup "wl-paste --type text --watch cliphist store"
spawn-sh-at-startup "wl-paste --type image --watch cliphist store"

// Scratchpad manager (works on any Wayland compositor)
spawn-at-startup "pypr"

// Rofi/app-launcher server
spawn-at-startup "vicinae" "server"

// Doorbell popup daemon
spawn-at-startup "/home/james/.local/bin/doorbell_popup"

// Glanceable web dashboard is launched by the systemd user unit
// webview-zone.service (WantedBy=graphical-session.target), not via
// spawn-at-startup, so Restart=always can respawn the process when
// screen sleep/DPMS disconnects HDMI-A-1 and tears down its layer-shell
// surface. Enable the unit with `systemctl --user enable --now
// webview-zone.service` on a fresh machine.

// Idle + lock — fully handled by Noctalia's IdleService (DPMS timeouts,
// lock, suspend) and its general.lockOnSuspend hook for systemd-initiated
// suspends. Configure timeouts in the Noctalia settings UI.

// === Layer rules ===

{{- if eq .machine "desktop" }}
// Float-panel look for webview-zone: rounded drop-shadow on the layer
// surface. niri's geometry-corner-radius only rounds the *shadow*, not the
// surface content — QtWebEngine can't be clipped to rounded bounds without
// breaking pointer events (Qt bug QTBUG-44666). The shadow alone reads as
// a floating panel; surface corners stay square by design.
layer-rule {
    match namespace="^webview-zone$"
    geometry-corner-radius 12
    shadow {
        on
        softness 32
        spread 4
        offset x=0 y=8
        color "#00000080"
    }
}
{{- end }}

// === Window rules ===

// Global: rounded corners + subtle inactive opacity to match hyprland look
window-rule {
    geometry-corner-radius 15
    clip-to-geometry true
}

// Float rules (ported 1:1 from hyprland windowrulev2 float entries)
window-rule { match app-id=r#"(?i)thunar"# title="File Operation Progress"; open-floating true; }
window-rule { match app-id=r#"(?i)thunar"# title="Confirm to replace files"; open-floating true; }
window-rule { match app-id=r#"xdg-desktop-portal-gtk"#; open-floating true; }
window-rule { match app-id=r#"org\.gnome\.Calculator"#; open-floating true; }
window-rule { match app-id=r#"(codium|codium-url-handler|VSCodium)"# title="Add Folder to Workspace"; open-floating true; }
window-rule { match app-id=r#"(?i)rofi"#; open-floating true; }
window-rule { match app-id=r#"^eog$"#; open-floating true; }
window-rule { match app-id=r#"^(pavucontrol|org\.pulseaudio\.pavucontrol)$"#; open-floating true; }
window-rule { match app-id=r#"^(nwg-look|qt5ct|qt6ct|mpv)$"#; open-floating true; }
window-rule { match app-id=r#"^(nm-applet|nm-connection-editor|blueman-manager)$"#; open-floating true; }
window-rule { match app-id=r#"^(gnome-system-monitor|org\.gnome\.SystemMonitor)$"#; open-floating true; }
window-rule { match app-id=r#"^yad$"#; open-floating true; }
window-rule { match app-id=r#"^(file-roller|org\.gnome\.FileRoller)$"#; open-floating true; }
window-rule { match app-id=r#"(?i)(baobab|org\.gnome\.baobab)"#; open-floating true; }
window-rule { match title="Kvantum Manager"; open-floating true; }
window-rule { match app-id=r#"(?i)qalculate-gtk"#; open-floating true; }

// Doorbell video popup
window-rule {
    match title=r#"^\[Doorbell\]"#
    open-floating true
    default-floating-position x=24 y=24 relative-to="top-right"
    default-column-width { fixed 400; }
    opacity 1.0
    border { off; }
}

// Camera grid feeds
window-rule {
    match title=r#"^\[Camera\]"#
    open-floating true
    default-floating-position x=24 y=24 relative-to="bottom-right"
    opacity 1.0
    border { off; }
}

// Hotkey overlay
hotkey-overlay {
    skip-at-startup
    hide-not-bound
}

// Recent-windows switcher (Alt+Tab-style). Its binds live here,
// not in the global `binds` block, because the UI closes as soon
// as the modifier is released.
recent-windows {
    // Catppuccin Mocha: mauve accent for the focused preview,
    // red for urgent. Corner radius matches typical GTK/marble roundness.
    highlight {
        active-color "#cba6f7ff"
        urgent-color "#f38ba8ff"
        padding 20
        corner-radius 12
    }

    binds {
        Mod+Tab       { next-window; }
        Mod+Shift+Tab { previous-window; }
    }
}

// === Binds ===
// Mod is Super on TTY.
binds {
    // Session
    Ctrl+Alt+Delete { quit; }
    Mod+Shift+E     { quit; }

    // Applications
    Mod+Return   hotkey-overlay-title="Terminal" { spawn "ghostty"; }
    Mod+T                                        { spawn "thunar"; }
    Mod+Space    hotkey-overlay-title="Launcher" { spawn "vicinae" "toggle"; }
    // Screen recording — wl-screenrec (wlr-screencopy, bypasses the broken
    // portal path that Kooha's pipewiresrc can't negotiate on niri).
    // First press starts recording, second press stops and copies path to clipboard.
    Mod+S       hotkey-overlay-title="Record region" { spawn "screenrec" "--mode" "region"; }
    Mod+Alt+S   hotkey-overlay-title="Record output" { spawn "screenrec" "--mode" "output"; }
    Mod+Shift+Alt+S hotkey-overlay-title="Record output + audio" { spawn "screenrec" "--mode" "output" "--audio"; }

    // Noctalia overlays (toggle via the noctalia-shell IPC)
    Mod+W        hotkey-overlay-title="Wallpaper picker" { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "wallpaper" "toggle"; }
    Mod+B        hotkey-overlay-title="Control Center"   { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "controlCenter" "toggle"; }
    Mod+Slash    hotkey-overlay-title="Notifications"    { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "notifications" "toggleHistory"; }
    Mod+L        hotkey-overlay-title="Session menu"     { spawn "qs" "-c" "noctalia-shell" "ipc" "call" "sessionMenu" "toggle"; }

    // Screenshot — niri's built-in interactive UI, plus the swappy pipeline
    //od+Shift+S     { screenshot; }
    Ctrl+Print      { screenshot-screen; }
    Alt+Print       { screenshot-window; }
    Mod+Shift+S   { spawn "/home/james/.config/hypr/scripts/ScreenShot.sh" "--swappy"; }

    // Window management
    Mod+Q repeat=false { close-window; }
    Mod+Shift+Q        { spawn "/home/james/.config/hypr/scripts/KillActiveProcess.sh"; }
    Mod+F              { toggle-window-floating; }
    // Mod+Shift+F     { fullscreen-window; }
    Mod+Shift+F        { maximize-column; }
    Mod+C              { spawn "niri_rescue_floating"; }

    // Columns (horizontal movement within a workspace)
    Mod+Left        { focus-column-left; }
    Mod+Right       { focus-column-right; }
    Mod+Shift+Left  { move-column-left; }
    Mod+Shift+Right { move-column-right; }
    Mod+Home        { focus-column-first; }
    Mod+End         { focus-column-last; }
    Mod+R           { switch-preset-column-width; }
    Mod+Shift+R     { switch-preset-window-height; }
    Mod+Ctrl+R      { reset-window-height; }
    Mod+Comma       { consume-window-into-column; }
    Mod+Period      { expel-window-from-column; }
    Mod+BracketLeft  { consume-or-expel-window-left; }
    Mod+BracketRight { consume-or-expel-window-right; }

    // Vertical arrows = workspace nav (laptop has no Page keys).
    // Shift variants carry the current column with you.
    Mod+Up         { focus-workspace-up; }
    Mod+Down       { focus-workspace-down; }
    Mod+Shift+Up   { move-column-to-workspace-up; }
    Mod+Shift+Down { move-column-to-workspace-down; }

    // Workspaces (niri-native: per-monitor, vertical)
    Mod+1 { focus-workspace 1; }
    Mod+2 { focus-workspace 2; }
    Mod+3 { focus-workspace 3; }
    Mod+4 { focus-workspace 4; }
    Mod+5 { focus-workspace 5; }
    Mod+6 { focus-workspace 6; }
    Mod+7 { focus-workspace 7; }
    Mod+8 { focus-workspace 8; }
    Mod+9 { focus-workspace 9; }
    Mod+Shift+1 { move-column-to-workspace 1; }
    Mod+Shift+2 { move-column-to-workspace 2; }
    Mod+Shift+3 { move-column-to-workspace 3; }
    Mod+Shift+4 { move-column-to-workspace 4; }
    Mod+Shift+5 { move-column-to-workspace 5; }
    Mod+Shift+6 { move-column-to-workspace 6; }
    Mod+Shift+7 { move-column-to-workspace 7; }
    Mod+Shift+8 { move-column-to-workspace 8; }
    Mod+Shift+9 { move-column-to-workspace 9; }

    Mod+Page_Up        { focus-workspace-up; }
    Mod+Page_Down      { focus-workspace-down; }
    Mod+Ctrl+Page_Up   { move-column-to-workspace-up; }
    Mod+Ctrl+Page_Down { move-column-to-workspace-down; }
    Mod+Shift+Page_Up   { move-workspace-up; }
    Mod+Shift+Page_Down { move-workspace-down; }

    // Laptop-friendly workspace nav (no Page keys on most laptops).
    // Vim-style: K=up, J=down. Shift variants carry the column along.
    Mod+K       { focus-workspace-up; }
    Mod+J       { focus-workspace-down; }
    Mod+Shift+K { move-column-to-workspace-up; }
    Mod+Shift+J { move-column-to-workspace-down; }

    Mod+WheelScrollDown      cooldown-ms=150 { focus-workspace-down; }
    Mod+WheelScrollUp        cooldown-ms=150 { focus-workspace-up; }
    Mod+WheelScrollRight      { focus-column-right; }
    Mod+WheelScrollLeft       { focus-column-left; }

    // Monitor navigation (niri-specific — useful on desktop multi-monitor)
    Mod+Alt+Left  { focus-monitor-left; }
    Mod+Alt+Right { focus-monitor-right; }
    Mod+Alt+Up    { focus-monitor-up; }
    Mod+Alt+Down  { focus-monitor-down; }

    // Overview
    Mod+O repeat=false { toggle-overview; }

    // Audio (mirrors hyprland binds)
    XF86AudioRaiseVolume allow-when-locked=true { spawn-sh "wpctl set-volume -l 1.5 @DEFAULT_AUDIO_SINK@ 0.01+"; }
    XF86AudioLowerVolume allow-when-locked=true { spawn-sh "wpctl set-volume @DEFAULT_AUDIO_SINK@ 0.01-"; }
    XF86AudioMute        allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle"; }
    XF86AudioMicMute     allow-when-locked=true { spawn-sh "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle"; }

    {{- if eq .machine "laptop" }}
    XF86MonBrightnessUp   allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "+10%"; }
    XF86MonBrightnessDown allow-when-locked=true { spawn "brightnessctl" "--class=backlight" "set" "10%-"; }

    // Touchpad two-finger scroll. Niri distinguishes these from WheelScroll*
    // (mouse wheel), so both sets need bindings on a laptop with no mouse.
    Mod+TouchpadScrollDown   cooldown-ms=150 { focus-workspace-down; }
    Mod+TouchpadScrollUp     cooldown-ms=150 { focus-workspace-up; }
    Mod+TouchpadScrollRight                  { focus-column-right; }
    Mod+TouchpadScrollLeft                   { focus-column-left; }
    {{- end }}

    // Output scale (runtime only — restart reverts to config value)
    Mod+Equal { spawn "niri_scale" "--step" "0.25"; }
    Mod+Minus { spawn "niri_scale" "--step" "-0.25"; }
    Mod+0     { spawn "niri_scale" "--set" "1.5"; }


    // Power
    Mod+Shift+P { power-off-monitors; }
}

// Noctalia writes live theming (colors, font, etc.) here.
include "./noctalia.kdl"
