#!/usr/bin/env python3
"""Re-center all floating niri windows that may have drifted off-screen.

This can happen after monitor hotplug or DPMS wake, when a floating
window's saved coordinates no longer land on a visible output.

Uses `niri msg`: lists all windows, filters for floating ones on
regular workspaces, then focuses each and invokes `center-window`.
"""

import json
import subprocess
import sys

from j_lib import JParser


def niri_windows() -> list[dict]:
    result = subprocess.run(
        ["niri", "msg", "--json", "windows"],
        capture_output=True,
        text=True,
        check=True,
    )
    return json.loads(result.stdout)


def focus(window_id: int) -> None:
    subprocess.run(
        ["niri", "msg", "action", "focus-window", "--id", str(window_id)],
        check=True,
    )


def center() -> None:
    subprocess.run(
        ["niri", "msg", "action", "center-window"],
        check=True,
    )


def main() -> int:
    parser = JParser(description="Re-center floating niri windows")
    parser.add_argument(
        "--dry-run",
        "-n",
        action="store_true",
        help="Show what would be done without making changes",
    )
    args = parser.run()

    windows = niri_windows()
    floating = [w for w in windows if w.get("is_floating")]

    if not floating:
        print("No floating windows to rescue.")
        return 0

    print(f"Found {len(floating)} floating window(s):")
    for w in floating:
        app = w.get("app_id") or "?"
        title = w.get("title") or ""
        print(f"  - [{w['id']}] {app}: {title!r}")

    if args.dry_run:
        print("\nDry run — no changes made.")
        return 0

    original = next((w["id"] for w in windows if w.get("is_focused")), None)

    for w in floating:
        focus(w["id"])
        center()
        print(f"  Centered [{w['id']}] {w.get('app_id') or '?'}")

    if original is not None:
        focus(original)

    print("Done.")
    return 0


if __name__ == "__main__":
    sys.exit(main())
