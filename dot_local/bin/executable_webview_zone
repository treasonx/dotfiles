#!/usr/bin/env python3
"""webview_zone — multi-URL glanceable dashboard in a wlr-layer-shell strut.

Qt6 + PySide6 + QtWebEngine + layer-shell-qt. Launches an always-on layer-shell
window at the top of a configured output, renders the TOML-configured URL list
as a horizontal SplitView of WebEngineViews. Drag-persist widths and shared
persistent Chromium profile.

Design notes: docs/plans/2026-04-19-feat-webview-zone-dashboard-plan.md
QML UI:       ~/.local/share/webview-zone/main.qml

Dependencies on Fedora 43:
    python3-pyside6  layer-shell-qt  qt6-qtwebengine
"""
import logging
import os
import signal
import sys
import tomllib
from dataclasses import dataclass
from pathlib import Path
from urllib.parse import urlparse

# Harden state-file perms before Qt/Chromium touch the profile directory.
os.umask(0o077)

# Force layer-shell as Qt's Wayland shell integration. Must be set BEFORE
# QGuiApplication is constructed.
os.environ["QT_WAYLAND_SHELL_INTEGRATION"] = "layer-shell"
os.environ.setdefault("QT_QPA_PLATFORM", "wayland")

# QtWebEngineQuick.initialize() must run before QGuiApplication per Chromium's
# CommandLine init contract. This is the reason QtWebEngine could not live
# inside a Quickshell plugin — qs doesn't run our init path.
from PySide6.QtWebEngineQuick import QtWebEngineQuick  # noqa: E402

QtWebEngineQuick.initialize()

from PySide6.QtCore import (  # noqa: E402
    QByteArray,
    QObject,
    QUrl,
    Property,
    Signal,
    Slot,
)
from PySide6.QtGui import QGuiApplication  # noqa: E402
from PySide6.QtNetwork import QLocalServer, QLocalSocket  # noqa: E402
from PySide6.QtQml import QQmlApplicationEngine  # noqa: E402

from j_lib import JParser  # noqa: E402


CONFIG = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config")) / "webview-zone" / "config.toml"
STATE = Path(os.environ.get("XDG_STATE_HOME", Path.home() / ".local/state")) / "webview-zone"
PROFILE = STATE / "profile"
SPLIT_STATE = STATE / "split-state.dat"
QML_FILE = Path.home() / ".local/share/webview-zone/main.qml"
INSTANCE_KEY = "webview-zone.morrin.dev"

log = logging.getLogger("webview_zone")


class ConfigError(Exception):
    """Raised for expected config problems (missing, malformed, invalid URL)."""


@dataclass(frozen=True, slots=True)
class Config:
    output: str
    zone_height: int
    geometry: tuple[int, int]
    urls: tuple[str, ...]


def _validate_url(u: str) -> str:
    p = urlparse(u)
    if p.scheme == "https":
        return u
    if p.scheme == "http" and (
        p.hostname in ("localhost", "127.0.0.1")
        or (p.hostname or "").endswith(".local")
    ):
        return u
    raise ConfigError(f"refusing non-https URL: {u!r}")


def load_config() -> Config:
    if not CONFIG.exists():
        raise ConfigError(f"config not found: {CONFIG}")
    with CONFIG.open("rb") as f:
        raw = tomllib.load(f)
    try:
        urls = tuple(_validate_url(u) for u in raw["urls"])
        if not urls:
            raise ConfigError("urls list is empty")
        geometry = tuple(int(x) for x in raw.get("geometry", [0, 0]))
        if len(geometry) != 2:
            raise ConfigError("geometry must be [width, height]")
        return Config(
            output=str(raw["output"]),
            zone_height=int(raw["zone_height"]),
            geometry=geometry,  # type: ignore[arg-type]
            urls=urls,
        )
    except KeyError as e:
        raise ConfigError(f"missing required key: {e.args[0]}") from e


def acquire_single_instance() -> QLocalServer | None:
    """Try to claim a named local socket. Returns the listening server on
    success, or None if another instance is already holding the name."""
    probe = QLocalSocket()
    probe.connectToServer(INSTANCE_KEY)
    if probe.waitForConnected(200):
        probe.close()
        return None

    # No live listener — clean up any stale socket file and try to listen.
    QLocalServer.removeServer(INSTANCE_KEY)
    server = QLocalServer()
    if not server.listen(INSTANCE_KEY):
        # Don't hard-fail if we can't get the lock — better to run a possible
        # duplicate than fail startup silently. Warn and continue.
        log.warning("single-instance lock unavailable: %s", server.errorString())
    return server


class Bridge(QObject):
    """Glue object exposing config and state helpers to QML."""

    savedSplitStateChanged = Signal()

    def __init__(self, cfg: Config, saved_state: bytes) -> None:
        super().__init__()
        self._cfg = cfg
        self._saved_state = QByteArray(saved_state)

    @Property(list, constant=True)
    def urls(self) -> list[str]:
        return list(self._cfg.urls)

    @Property(int, constant=True)
    def zoneHeight(self) -> int:
        return self._cfg.zone_height

    @Property(str, constant=True)
    def profilePath(self) -> str:
        return str(PROFILE)

    @Property(QByteArray, notify=savedSplitStateChanged)
    def savedSplitState(self) -> QByteArray:
        return self._saved_state

    @Slot(QByteArray)
    def persistSplitState(self, state: QByteArray) -> None:
        try:
            SPLIT_STATE.write_bytes(bytes(state))
        except OSError as e:
            log.warning("failed to persist split state: %s", e)


def main() -> int:
    logging.basicConfig(
        level=logging.INFO,
        format="%(asctime)s webview_zone %(levelname)s %(message)s",
    )
    JParser(description="Multi-URL glanceable dashboard (Qt/Chromium in wlr-layer-shell)").run()

    try:
        cfg = load_config()
    except (FileNotFoundError, tomllib.TOMLDecodeError, ConfigError) as e:
        log.error("config: %s", e)
        return 1

    STATE.mkdir(parents=True, exist_ok=True)
    PROFILE.mkdir(mode=0o700, parents=True, exist_ok=True)
    os.chmod(PROFILE, 0o700)

    saved_state = SPLIT_STATE.read_bytes() if SPLIT_STATE.exists() else b""

    app = QGuiApplication(sys.argv)
    app.setApplicationName("webview-zone")
    app.setApplicationDisplayName("webview-zone")

    lock = acquire_single_instance()
    if lock is None:
        log.info("another instance already holds %s; exiting", INSTANCE_KEY)
        return 0

    # Clean shutdown on SIGTERM (niri/systemd stop, logout, etc.)
    signal.signal(signal.SIGTERM, lambda *_: app.quit())

    bridge = Bridge(cfg, saved_state)

    if not QML_FILE.exists():
        log.error("QML file not found: %s", QML_FILE)
        return 1

    engine = QQmlApplicationEngine()
    engine.rootContext().setContextProperty("bridge", bridge)
    engine.load(QUrl.fromLocalFile(str(QML_FILE)))

    if not engine.rootObjects():
        log.error("failed to load QML")
        return 1

    log.info("webview_zone running: %d pane(s) on %r", len(cfg.urls), cfg.output)
    return app.exec()


if __name__ == "__main__":
    sys.exit(main())
