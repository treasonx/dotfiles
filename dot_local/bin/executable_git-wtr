#!/usr/bin/env python3
"""Remove a git worktree using fzf for selection."""

import subprocess
import sys

from j_lib import JParser

parser = JParser(description="Remove git worktree via fzf picker")
parser.run()

# List worktrees, skip bare repo (first line)
result = subprocess.run(
    ["git", "worktree", "list"], capture_output=True, text=True,
)
lines = [
    line for line in result.stdout.strip().splitlines()[1:]
    if "(bare)" not in line
]

if not lines:
    print("No worktrees to remove")
    sys.exit(0)

# Pick with fzf
fzf = subprocess.run(
    ["fzf", "--prompt=Remove worktree: "],
    input="\n".join(lines), capture_output=True, text=True,
)
if fzf.returncode != 0 or not fzf.stdout.strip():
    sys.exit(0)

path = fzf.stdout.strip().split()[0]
rm = subprocess.run(["git", "worktree", "remove", path], capture_output=True, text=True)

if rm.returncode == 0:
    print(rm.stdout, end="")
else:
    print(rm.stderr, end="")
    # Show untracked/modified files blocking removal
    status = subprocess.run(
        ["git", "-C", path, "status", "--short"],
        capture_output=True, text=True,
    )
    if status.stdout.strip():
        print(f"\nBlocking files in {path}:")
        print(status.stdout)
    answer = input("Force remove worktree? [y/N] ").strip().lower()
    if answer == "y":
        subprocess.run(["git", "worktree", "remove", "--force", path])
    else:
        print("Aborted")
