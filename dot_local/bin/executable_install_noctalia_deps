#!/usr/bin/env python3
"""Install Noctalia Shell + optional deps on Fedora.

Noctalia is a Wayland desktop shell built on Quickshell (QML). As of v4.6.1
it requires `noctalia-qs`, a maintained Quickshell fork. The Fedora-official
distribution path (per upstream docs) is the Terra repository, which ships
both `noctalia-shell` (QML config) and `noctalia-qs` (runtime) as RPMs.

Usage:
    install_noctalia_deps                # Install everything
    install_noctalia_deps --check        # Report status only
    install_noctalia_deps --skip-optional  # Required packages only
"""

from j_lib import JParser
import subprocess
import sys


# Terra bootstrap — the $releasever placeholder is expanded by dnf, so this
# single definition works on any Fedora release.
TERRA_REPO_PATH = "terra,https://repos.fyralabs.com/terra$releasever"

# Core Noctalia runtime. noctalia-qs is pulled transitively by noctalia-shell,
# listed here so --check flags a partial install clearly.
REQUIRED = [
    "terra-release",    # Bootstraps the Terra repo definition + GPG key
    "noctalia-shell",   # QML shell config
    "noctalia-qs",      # Quickshell fork (required by noctalia-shell v4.6.1+)
]

# Optional but recommended by Noctalia docs + to match current user stack.
OPTIONAL = [
    "cava",                        # Audio visualizer (Noctalia media panel)
    "cliphist",                    # Clipboard history for the launcher
    "brightnessctl",               # Internal / laptop screen brightness
    "ddcutil",                     # External monitor brightness via DDC/CI
    "wlsunset",                    # Night-light fallback
    "matugen",                     # Wallpaper-based color generation (OFF by
                                   # default — user prefers static palettes)
    "google-roboto-fonts",         # Noctalia UI default font family
    "rsms-inter-fonts",            # Alt UI font (fontDefault in settings)
    "jetbrains-mono-nerd-fonts",   # Bar / fixed-width font
]


def run(cmd: list[str], check: bool = True) -> subprocess.CompletedProcess:
    return subprocess.run(cmd, capture_output=True, text=True, check=check)


def is_installed(package: str) -> bool:
    return run(["rpm", "-q", package], check=False).returncode == 0


def ensure_terra():
    """Add the Terra repo if missing. terra-release manages its own GPG key."""
    if is_installed("terra-release"):
        return
    print("\nBootstrapping Terra repository...")
    subprocess.run(
        [
            "sudo", "dnf", "install", "-y", "--nogpgcheck",
            "--repofrompath", TERRA_REPO_PATH, "terra-release",
        ],
        check=True,
    )


def check_status():
    """Print installation status. Returns (missing_required, missing_optional)."""
    missing_required = []
    for pkg in REQUIRED:
        installed = is_installed(pkg)
        status = "installed" if installed else "MISSING"
        print(f"  {pkg}: {status}")
        if not installed:
            missing_required.append(pkg)

    missing_optional = []
    print()
    for pkg in OPTIONAL:
        installed = is_installed(pkg)
        status = "installed" if installed else "missing"
        print(f"  {pkg}: {status}")
        if not installed:
            missing_optional.append(pkg)

    return missing_required, missing_optional


def main():
    parser = JParser(description="Install Noctalia Shell + optional deps")
    parser.add_argument("--check", action="store_true",
                        help="Only check status, don't install")
    parser.add_argument("--skip-optional", action="store_true",
                        help="Install required packages only")
    args = parser.run()

    print("Noctalia dependency status:\n")
    missing_required, missing_optional = check_status()

    if args.check:
        sys.exit(0 if not missing_required else 1)

    ensure_terra()
    # Re-check REQUIRED after the Terra bootstrap (terra-release is now installed).
    missing_required = [p for p in REQUIRED if not is_installed(p)]

    if missing_required:
        print(f"\nInstalling required: {missing_required}")
        subprocess.run(["sudo", "dnf", "install", "-y", *missing_required], check=True)

    if not args.skip_optional and missing_optional:
        print(f"\nInstalling optional: {missing_optional}")
        subprocess.run(["sudo", "dnf", "install", "-y", *missing_optional], check=True)

    print("\nDone. Start with: qs -c noctalia-shell")


if __name__ == "__main__":
    main()
