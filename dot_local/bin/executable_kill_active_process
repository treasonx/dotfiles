#!/usr/bin/env python3
"""SIGTERM the process owning niri's focused window.

More aggressive than `close-window` — use when an app is unresponsive.
Niri binds Mod+Shift+Q to this.
"""

import json
import os
import signal
import subprocess
import sys

from j_lib import JParser


def main() -> int:
    parser = JParser(description="SIGTERM the focused window's process")
    parser.run()

    result = subprocess.run(
        ["niri", "msg", "--json", "focused-window"],
        capture_output=True,
        text=True,
        check=True,
    )
    window = json.loads(result.stdout)
    if not window:
        print("No focused window", file=sys.stderr)
        return 1

    pid = window.get("pid")
    if not pid:
        print(f"Focused window has no pid: {window!r}", file=sys.stderr)
        return 1

    os.kill(pid, signal.SIGTERM)
    return 0


if __name__ == "__main__":
    sys.exit(main())
