#!/usr/bin/env python3
"""Niri IPC bridge for the AGS sidebar Cast tab.

Speaks the niri IPC protocol over $NIRI_SOCKET. Subcommands:

  event-stream    Long-lived: stream debounced state snapshots as NDJSON
  snapshot        One-shot: emit a single full state snapshot
  windows         List windows as JSON
  outputs         List outputs as JSON
  casts           List casts as JSON
  set-window [id] Retarget dynamic cast to a window (focused if id omitted)
  set-monitor [n] Retarget dynamic cast to an output (focused if name omitted)
  clear           Clear the dynamic cast target
  pick            Pick a window via niri's overlay; print {id,title} or null

Niri detail: once a socket sends Request::EventStream, niri stops reading
further requests on that socket. Therefore we use TWO sockets — one
long-lived event-stream reader, one short-lived per-request socket for
actions and queries.

State snapshot shape (one JSON object per line on stdout):
  {
    "casts": [{"id":7,"is_dynamic_target":true,"is_active":true,
               "target":{"kind":"Window","window_id":42}}],
    "windows": [{"id":42,"app_id":"firefox","title":"...",
                 "workspace_id":3,"is_focused":false,
                 "focus_timestamp":1234567}],
    "workspaces": [{"id":3,"idx":2,"name":null,"output":"DP-1"}],
    "outputs": [{"name":"DP-1","make":"...","logical":{...}}]
  }

Disconnect sentinel (emitted while reconnecting):
  {"_disconnected": true, "reason": "..."}
"""

import json
import os
import socket
import sys
import time
from typing import Any

from j_lib import JParser

SOCKET_ENV = "NIRI_SOCKET"
DEBOUNCE_SECONDS = 0.1
RECONNECT_DELAYS = [1, 2, 5, 10, 30]  # seconds, capped at last value


# ── Socket plumbing ───────────────────────────────────────────────────


def socket_path() -> str:
    """Return $NIRI_SOCKET or exit 1 with a helpful message."""
    path = os.environ.get(SOCKET_ENV)
    if not path:
        print(
            f"{SOCKET_ENV} is not set — niri is not running, or this shell "
            f"isn't inside the niri session.",
            file=sys.stderr,
        )
        sys.exit(1)
    return path


def open_socket() -> socket.socket:
    """Connect to the niri IPC socket. Raises on failure."""
    sock = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    sock.connect(socket_path())
    return sock


def request(payload: Any) -> Any:
    """Send one Request, read one Reply, return the inner value.

    Niri's Reply envelope is `{"Ok": <value>} | {"Err": <string>}`.
    Returns the unwrapped Ok value, or exits 1 on Err.
    """
    sock = open_socket()
    try:
        sock.sendall((json.dumps(payload) + "\n").encode("utf-8"))
        sock.shutdown(socket.SHUT_WR)
        # Niri responds with a single line for non-EventStream requests.
        buf = b""
        while True:
            chunk = sock.recv(65536)
            if not chunk:
                break
            buf += chunk
            if b"\n" in chunk:
                break
        line = buf.split(b"\n", 1)[0].decode("utf-8").strip()
        reply = json.loads(line)
    finally:
        sock.close()

    if isinstance(reply, dict) and "Err" in reply:
        print(f"niri IPC error: {reply['Err']}", file=sys.stderr)
        sys.exit(1)
    if isinstance(reply, dict) and "Ok" in reply:
        return reply["Ok"]
    # Niri 25.11 sometimes returns the bare value; tolerate it.
    return reply


# ── Snapshot assembly ─────────────────────────────────────────────────
#
# We coalesce the four query responses into a single state object that the
# AGS Cast tab consumes verbatim. The same shape is emitted by `snapshot`
# (one-shot) and by `event-stream` (debounced after each Event).


def assemble_snapshot(state: dict) -> dict:
    """Project niri's raw IPC structures into the AGS-facing schema.

    `state` is a dict of the latest seen response/event payloads, keyed by
    "casts", "windows", "workspaces", "outputs". Missing keys default to [].
    """
    casts_raw = state.get("casts") or []
    windows_raw = state.get("windows") or []
    workspaces_raw = state.get("workspaces") or []
    outputs_raw = state.get("outputs") or {}

    casts = [project_cast(c) for c in casts_raw]
    windows = [project_window(w) for w in windows_raw]
    workspaces = [project_workspace(w) for w in workspaces_raw]
    # `outputs` is HashMap<String, Output> — flatten to a list with name field.
    if isinstance(outputs_raw, dict):
        outputs = [project_output(name, o) for name, o in outputs_raw.items()]
    else:
        outputs = [project_output(o.get("name", ""), o) for o in outputs_raw]

    return {
        "casts": casts,
        "windows": windows,
        "workspaces": workspaces,
        "outputs": outputs,
    }


def project_cast(c: dict) -> dict:
    """Project a niri Cast into the AGS schema.

    CastTarget variants: Nothing {} | Output {name} | Window {window_id}.
    Niri encodes enum variants as `{"VariantName": {...}}`.
    """
    target_raw = c.get("target") or {}
    if isinstance(target_raw, dict) and target_raw:
        kind, payload = next(iter(target_raw.items()))
        if not isinstance(payload, dict):
            payload = {}
        target = {"kind": kind, **payload}
    else:
        target = {"kind": "Nothing"}
    return {
        "id": c.get("id"),
        "stream_id": c.get("stream_id", c.get("id")),
        "is_dynamic_target": bool(c.get("is_dynamic_target", False)),
        "is_active": bool(c.get("is_active", False)),
        "target": target,
    }


def project_window(w: dict) -> dict:
    return {
        "id": w.get("id"),
        "app_id": w.get("app_id"),
        "title": w.get("title"),
        "workspace_id": w.get("workspace_id"),
        "is_focused": bool(w.get("is_focused", False)),
        "is_floating": bool(w.get("is_floating", False)),
        "focus_timestamp": w.get("focus_timestamp"),
    }


def project_workspace(ws: dict) -> dict:
    return {
        "id": ws.get("id"),
        "idx": ws.get("idx"),
        "name": ws.get("name"),
        "output": ws.get("output"),
        "is_active": bool(ws.get("is_active", False)),
        "is_focused": bool(ws.get("is_focused", False)),
    }


def project_output(name: str, o: dict) -> dict:
    return {
        "name": name or o.get("name"),
        "make": o.get("make"),
        "model": o.get("model"),
        "logical": o.get("logical"),
    }


# ── Subcommands: one-shot queries ─────────────────────────────────────


def cmd_snapshot() -> int:
    state = {
        "casts": request("Casts"),
        "windows": request("Windows"),
        "workspaces": request("Workspaces"),
        "outputs": request("Outputs"),
    }
    json.dump(assemble_snapshot(state), sys.stdout, separators=(",", ":"))
    sys.stdout.write("\n")
    return 0


def cmd_query(name: str) -> int:
    """Generic query — emit raw projected data for one entity type."""
    if name == "windows":
        result = [project_window(w) for w in request("Windows")]
    elif name == "outputs":
        outputs_raw = request("Outputs")
        if isinstance(outputs_raw, dict):
            result = [project_output(n, o) for n, o in outputs_raw.items()]
        else:
            result = [project_output(o.get("name", ""), o) for o in outputs_raw]
    elif name == "casts":
        result = [project_cast(c) for c in request("Casts")]
    else:
        print(f"unknown query: {name}", file=sys.stderr)
        return 1
    json.dump(result, sys.stdout, separators=(",", ":"))
    sys.stdout.write("\n")
    return 0


# ── Subcommands: actions ──────────────────────────────────────────────
#
# Niri Action enum is encoded as `{"Action": {"VariantName": {...}}}`
# inside a Request. The Reply for actions is `{"Ok": "Handled"}` — we
# don't print it, just verify it.


def action(variant: str, payload: dict | None = None) -> int:
    body = {variant: payload or {}}
    request({"Action": body})
    return 0


def cmd_set_window(window_id: int | None) -> int:
    return action("SetDynamicCastWindow", {"id": window_id})


def cmd_set_monitor(output: str | None) -> int:
    return action("SetDynamicCastMonitor", {"output": output})


def cmd_clear() -> int:
    return action("ClearDynamicCastTarget", {})


def cmd_pick() -> int:
    """niri msg pick-window — returns the picked Window or None on cancel."""
    result = request("PickWindow")
    # Response shape: {"PickedWindow": <Window | null>} or just the value.
    if isinstance(result, dict) and "PickedWindow" in result:
        result = result["PickedWindow"]
    if not result:
        json.dump(None, sys.stdout)
        sys.stdout.write("\n")
        return 0
    json.dump(
        {"id": result.get("id"), "title": result.get("title"),
         "app_id": result.get("app_id")},
        sys.stdout, separators=(",", ":"),
    )
    sys.stdout.write("\n")
    return 0


# ── Subcommand: event-stream ──────────────────────────────────────────
#
# Open a long-lived socket, send Request::EventStream, then read NDJSON
# events forever. Maintain in-memory state, debounce changes, emit one
# state snapshot per debounce window. Reconnect with exponential backoff
# on EOF, emitting a {"_disconnected": true} sentinel during the gap.


def event_stream_session(state: dict) -> None:
    """One connection's worth of event handling. Returns on EOF.

    Mutates `state` in place so the snapshot stays current across
    reconnects (niri re-emits initial state on each connect anyway).
    """
    sock = open_socket()
    try:
        sock.sendall(b'"EventStream"\n')
        sock.shutdown(socket.SHUT_WR)

        buf = b""
        last_emit = 0.0
        dirty = False

        # Use a non-blocking timeout so we can periodically flush a
        # debounced snapshot even when events arrive in a burst then pause.
        sock.settimeout(DEBOUNCE_SECONDS)

        while True:
            try:
                chunk = sock.recv(65536)
            except socket.timeout:
                # Quiet period — flush if dirty.
                if dirty:
                    emit_snapshot(state)
                    last_emit = time.monotonic()
                    dirty = False
                continue

            if not chunk:
                # Flush any pending change before reconnecting.
                if dirty:
                    emit_snapshot(state)
                return

            buf += chunk
            while b"\n" in buf:
                line, buf = buf.split(b"\n", 1)
                line = line.strip()
                if not line:
                    continue
                try:
                    msg = json.loads(line.decode("utf-8"))
                except json.JSONDecodeError:
                    continue
                # Skip the initial Reply envelope ({"Ok":"Handled"}).
                if isinstance(msg, dict) and ("Ok" in msg or "Err" in msg):
                    continue
                if apply_event(state, msg):
                    dirty = True

            # Burst-coalesce: if it's been ≥DEBOUNCE since last emit, flush.
            now = time.monotonic()
            if dirty and (now - last_emit) >= DEBOUNCE_SECONDS:
                emit_snapshot(state)
                last_emit = now
                dirty = False
    finally:
        sock.close()


def apply_event(state: dict, event: Any) -> bool:
    """Update in-memory state from one niri Event. Return True if changed.

    Niri encodes Event variants as `{"VariantName": {...payload}}`.
    We only handle the variants the Cast tab cares about; unknown ones
    are tolerated (niri-ipc adds variants in patch releases).
    """
    if not isinstance(event, dict) or not event:
        return False
    name, payload = next(iter(event.items()))
    if not isinstance(payload, dict):
        payload = {}

    if name == "WindowsChanged":
        state["windows"] = payload.get("windows", [])
        return True
    if name == "WindowOpenedOrChanged":
        return upsert_by_id(state.setdefault("windows", []),
                            payload.get("window") or {}, "id")
    if name == "WindowClosed":
        return remove_by_id(state.setdefault("windows", []),
                            payload.get("id"), "id")
    if name == "WindowFocusChanged":
        # Update focus flag on whichever window matches.
        focused = payload.get("id")
        changed = False
        for w in state.setdefault("windows", []):
            new = (w.get("id") == focused)
            if w.get("is_focused") != new:
                w["is_focused"] = new
                changed = True
        return changed
    if name == "WorkspacesChanged":
        state["workspaces"] = payload.get("workspaces", [])
        return True
    if name in ("WorkspaceActivated", "WorkspaceActiveWindowChanged"):
        # Coarse: just mark dirty so the next snapshot picks up via Workspaces query.
        return True
    if name == "CastsChanged":
        state["casts"] = payload.get("casts", [])
        return True
    if name == "CastStartedOrChanged":
        return upsert_by_id(state.setdefault("casts", []),
                            payload.get("cast") or {}, "id")
    if name == "CastStopped":
        return remove_by_id(state.setdefault("casts", []),
                            payload.get("stream_id") or payload.get("id"),
                            "stream_id") or remove_by_id(
                                state.setdefault("casts", []),
                                payload.get("stream_id") or payload.get("id"),
                                "id")
    # Unknown variant — ignore.
    return False


def upsert_by_id(lst: list, item: dict, key: str) -> bool:
    item_id = item.get(key)
    if item_id is None:
        return False
    for i, existing in enumerate(lst):
        if existing.get(key) == item_id:
            if existing == item:
                return False
            lst[i] = item
            return True
    lst.append(item)
    return True


def remove_by_id(lst: list, item_id: Any, key: str) -> bool:
    if item_id is None:
        return False
    for i, existing in enumerate(lst):
        if existing.get(key) == item_id:
            del lst[i]
            return True
    return False


def emit_snapshot(state: dict) -> None:
    """Write one NDJSON snapshot line and flush."""
    json.dump(assemble_snapshot(state), sys.stdout, separators=(",", ":"))
    sys.stdout.write("\n")
    sys.stdout.flush()


def cmd_event_stream() -> int:
    """Stream debounced state snapshots forever, reconnecting on EOF."""
    state: dict = {
        "casts": [], "windows": [], "workspaces": [], "outputs": {},
    }
    attempt = 0
    while True:
        try:
            # `outputs` doesn't have an event variant; refresh it on each
            # (re)connect via a one-shot query before opening the stream.
            try:
                state["outputs"] = request("Outputs")
            except Exception:  # noqa: BLE001
                state["outputs"] = {}
            event_stream_session(state)
            attempt = 0  # Successful connection — reset backoff.
            # event_stream_session returned EOF; emit sentinel + reconnect.
            json.dump({"_disconnected": True, "reason": "eof"}, sys.stdout)
            sys.stdout.write("\n")
            sys.stdout.flush()
        except (FileNotFoundError, ConnectionRefusedError, OSError) as e:
            json.dump(
                {"_disconnected": True, "reason": str(e)},
                sys.stdout,
            )
            sys.stdout.write("\n")
            sys.stdout.flush()

        delay = RECONNECT_DELAYS[min(attempt, len(RECONNECT_DELAYS) - 1)]
        attempt += 1
        time.sleep(delay)


# ── Entry ─────────────────────────────────────────────────────────────


def main() -> int:
    parser = JParser(description="Niri IPC bridge for AGS Cast tab")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("event-stream", help="Stream debounced state snapshots")
    sub.add_parser("snapshot", help="Emit one full state snapshot")
    sub.add_parser("windows", help="List windows as JSON")
    sub.add_parser("outputs", help="List outputs as JSON")
    sub.add_parser("casts", help="List casts as JSON")

    p_setw = sub.add_parser("set-window",
                            help="Retarget dynamic cast to a window")
    p_setw.add_argument("window_id", type=int, nargs="?",
                        help="Window id (focused window if omitted)")

    p_setm = sub.add_parser("set-monitor",
                            help="Retarget dynamic cast to an output")
    p_setm.add_argument("output", nargs="?",
                        help="Output name (focused output if omitted)")

    sub.add_parser("clear", help="Clear the dynamic cast target")
    sub.add_parser("pick",
                   help="Pick a window via niri's overlay; print id+title")

    args = parser.run()

    if args.command == "event-stream":
        try:
            return cmd_event_stream()
        except KeyboardInterrupt:
            return 0
    if args.command == "snapshot":
        return cmd_snapshot()
    if args.command in ("windows", "outputs", "casts"):
        return cmd_query(args.command)
    if args.command == "set-window":
        return cmd_set_window(args.window_id)
    if args.command == "set-monitor":
        return cmd_set_monitor(args.output)
    if args.command == "clear":
        return cmd_clear()
    if args.command == "pick":
        return cmd_pick()

    parser.print_help()
    return 1


if __name__ == "__main__":
    sys.exit(main())
