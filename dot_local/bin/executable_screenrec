#!/usr/bin/env python3
"""
Toggle screen recording via wl-screenrec.

Uses the wlr-screencopy protocol (not xdg-desktop-portal), so it sidesteps
the PipeWire DMA-BUF negotiation issues that break Kooha on niri.

Second invocation stops the active recording, flushes the MP4, copies the
resulting path to the Wayland clipboard, and fires a desktop notification.

Recordings land in ~/Videos/Screenrecs/.
"""

from __future__ import annotations

import datetime as dt
import os
import signal
import subprocess
import sys
import time
from pathlib import Path

from j_lib import JParser

PID_FILE = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "screenrec.pid"
META_FILE = Path(os.environ.get("XDG_RUNTIME_DIR", "/tmp")) / "screenrec.meta"
OUTPUT_DIR = Path.home() / "Videos" / "Screenrecs"
APP_NAME = "Screen recorder"


def notify(title: str, body: str = "", urgency: str = "normal") -> None:
    cmd = ["notify-send", "-a", APP_NAME, "-u", urgency, title]
    if body:
        cmd.append(body)
    subprocess.run(cmd, check=False)


def running_pid() -> int | None:
    if not PID_FILE.exists():
        return None
    try:
        pid = int(PID_FILE.read_text().strip())
        os.kill(pid, 0)
        return pid
    except (ValueError, ProcessLookupError, PermissionError):
        PID_FILE.unlink(missing_ok=True)
        META_FILE.unlink(missing_ok=True)
        return None


def focused_output() -> str:
    result = subprocess.run(
        ["niri", "msg", "--json", "focused-output"],
        capture_output=True, text=True, check=True,
    )
    import json
    return json.loads(result.stdout)["name"]


def pick_region() -> str:
    # slurp prints "x,y WxH" which wl-screenrec consumes directly via -g.
    result = subprocess.run(["slurp"], capture_output=True, text=True)
    if result.returncode != 0:
        raise SystemExit("Region selection cancelled")
    return result.stdout.strip()


def start(mode: str, audio: bool) -> None:
    if running_pid():
        notify("Already recording", "Run toggle again to stop.", "low")
        return

    OUTPUT_DIR.mkdir(parents=True, exist_ok=True)
    filename = OUTPUT_DIR / dt.datetime.now().strftime("Screenrec %Y-%m-%d %H-%M-%S.mp4")

    # low-power mode isn't implemented on the Phoenix iGPU; skip the failing probe.
    cmd = ["wl-screenrec", "-f", str(filename), "--low-power", "off"]
    if mode == "region":
        cmd += ["-g", pick_region()]
        label = "region"
    elif mode == "output":
        out = focused_output()
        cmd += ["-o", out]
        label = f"output {out}"
    else:
        raise SystemExit(f"Unknown mode: {mode}")

    if audio:
        cmd += ["--audio"]
        label += " + audio"

    # Start detached so the recording survives this script exiting.
    # setsid + start_new_session so SIGINT to the parent shell doesn't hit it.
    proc = subprocess.Popen(
        cmd,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )

    # Brief sanity check — if it dies immediately, report failure.
    time.sleep(0.3)
    if proc.poll() is not None:
        notify("Recording failed to start",
               f"wl-screenrec exited {proc.returncode}. Check `journalctl --user`.",
               "critical")
        raise SystemExit(proc.returncode or 1)

    PID_FILE.write_text(str(proc.pid))
    META_FILE.write_text(str(filename))
    notify("Recording started", label)


def stop() -> None:
    pid = running_pid()
    if pid is None:
        notify("Not recording", "", "low")
        return

    filename = META_FILE.read_text().strip() if META_FILE.exists() else ""

    # wl-screenrec flushes the muxer on SIGTERM/SIGINT. SIGINT is the documented one.
    os.kill(pid, signal.SIGINT)

    # Wait up to 5s for the file to be finalized.
    for _ in range(50):
        try:
            os.kill(pid, 0)
        except ProcessLookupError:
            break
        time.sleep(0.1)

    PID_FILE.unlink(missing_ok=True)
    META_FILE.unlink(missing_ok=True)

    if filename and Path(filename).exists():
        subprocess.run(["wl-copy"], input=filename, text=True, check=False)
        notify("Recording saved", f"{filename}\n(path copied to clipboard)")
    else:
        notify("Recording stopped", "Output file not found", "critical")


def main() -> None:
    parser = JParser(description="Toggle screen recording (wl-screenrec)")
    parser.add_argument(
        "--mode", "-m",
        choices=["region", "output"],
        default="region",
        help="What to capture when starting a new recording",
    )
    parser.add_argument(
        "--audio", "-a",
        action="store_true",
        help="Include default audio device in the recording",
    )
    args = parser.run()

    if running_pid():
        stop()
    else:
        start(args.mode, args.audio)


if __name__ == "__main__":
    main()
