#!/usr/bin/env python3
"""Adjust the fractional scale of a niri output at runtime.

Niri's `msg output ... scale <N>` only accepts absolute values, so this
wraps it: query the focused output's current scale via IPC, add the step
(or use --set), clamp to a sane range, and apply. Does not persist —
a niri restart reverts to whatever the config block specifies.
"""

import json
import subprocess
import sys

from j_lib import JParser

MIN_SCALE = 1.0
MAX_SCALE = 2.0


def focused_output() -> dict:
    result = subprocess.run(
        ["niri", "msg", "--json", "focused-output"],
        capture_output=True,
        text=True,
        check=True,
    )
    return json.loads(result.stdout)


def set_scale(connector: str, scale: float) -> None:
    subprocess.run(
        ["niri", "msg", "output", connector, "scale", f"{scale:g}"],
        check=True,
    )


def main() -> int:
    parser = JParser(description="Adjust niri output scale")
    group = parser.add_mutually_exclusive_group(required=True)
    group.add_argument(
        "--step",
        type=float,
        help="Relative change to current scale (e.g. 0.25 or -0.25)",
    )
    group.add_argument(
        "--set",
        dest="set_to",
        type=float,
        help="Absolute scale value (e.g. 1.5)",
    )
    args = parser.run()

    output = focused_output()
    connector = output["name"]
    current = float(output["logical"]["scale"])

    new = args.set_to if args.set_to is not None else current + args.step
    new = max(MIN_SCALE, min(MAX_SCALE, new))

    if abs(new - current) < 1e-6:
        print(f"{connector}: already at scale {current:g}")
        return 0

    set_scale(connector, new)
    print(f"{connector}: {current:g} -> {new:g}")

    # Floating windows are positioned in logical px — after a scale change the
    # logical working area resizes and previously-valid coords can land off-screen.
    # Re-center them so nothing gets stranded. Tiled columns reflow on their own.
    subprocess.run(["niri_rescue_floating"], check=False)
    return 0


if __name__ == "__main__":
    sys.exit(main())
