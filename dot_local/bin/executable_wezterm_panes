#!/usr/bin/env python3
"""WezTerm pane overview for AGS sidebar.

Reads pane state written by WezTerm's update-status Lua callback,
enriches it with git status and process info, outputs JSON.

Commands:
    enrich              Read state file, add git/process data, output JSON
    activate <pane_id>  Focus a pane and raise WezTerm window
"""

from j_lib import JParser
import json
import os
import subprocess
import sys
from concurrent.futures import ThreadPoolExecutor, as_completed
from pathlib import Path
from urllib.parse import urlparse

STATE_FILE = Path.home() / ".local" / "state" / "wezterm" / "panes.json"
HOME = str(Path.home())


def parse_cwd(raw_cwd: str) -> str:
    """Strip file://hostname prefix from WezTerm CWD URLs."""
    if not raw_cwd:
        return ""
    if raw_cwd.startswith("file://"):
        parsed = urlparse(raw_cwd)
        return parsed.path or ""
    return raw_cwd


def shorten_path(path: str) -> str:
    """Replace $HOME with ~ for display."""
    if path.startswith(HOME):
        return "~" + path[len(HOME):]
    return path


def get_git_status(cwd: str) -> dict | None:
    """Get git branch, dirty state, and worktree detection for a directory.

    Worktree detection: `git rev-parse --git-dir` returns a path containing
    `/worktrees/` when inside a worktree (e.g. /repo/.git/worktrees/feat-x),
    vs plain `.git` for the main checkout.
    """
    if not cwd or not os.path.isdir(cwd):
        return None
    try:
        result = subprocess.run(
            ["git", "-C", cwd, "status", "--porcelain=v2", "-b"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0:
            return None

        branch = ""
        ahead = 0
        behind = 0
        dirty_count = 0

        for line in result.stdout.splitlines():
            if line.startswith("# branch.head "):
                branch = line.split(" ", 2)[2]
            elif line.startswith("# branch.ab "):
                parts = line.split()
                ahead = int(parts[2].lstrip("+"))
                behind = abs(int(parts[3].lstrip("-")))
            elif not line.startswith("#"):
                dirty_count += 1

        if not branch:
            return None

        # Detect worktree: --git-dir contains /worktrees/ for linked worktrees
        is_worktree = False
        try:
            git_dir = subprocess.run(
                ["git", "-C", cwd, "rev-parse", "--git-dir"],
                capture_output=True, text=True, timeout=2,
            )
            if git_dir.returncode == 0:
                is_worktree = "/worktrees/" in git_dir.stdout.strip()
        except (subprocess.TimeoutExpired, OSError):
            pass

        return {
            "branch": branch,
            "dirty": dirty_count > 0,
            "ahead": ahead,
            "behind": behind,
            "worktree": is_worktree,
        }
    except (subprocess.TimeoutExpired, OSError):
        return None


def get_git_root_name(cwd: str) -> str | None:
    """Get the git repository root folder name for a directory."""
    if not cwd or not os.path.isdir(cwd):
        return None
    try:
        result = subprocess.run(
            ["git", "-C", cwd, "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode == 0:
            return Path(result.stdout.strip()).name
        return None
    except (subprocess.TimeoutExpired, OSError):
        return None


def get_process_info(tty_name: str) -> dict | None:
    """Get foreground process args, PID, and CPU% from a TTY.

    Uses a single `ps` call with pid, %cpu, and args columns.
    The most recently forked process (highest PID, last line) is
    typically the foreground process.
    """
    if not tty_name:
        return None
    # tty_name is like /dev/pts/3, ps wants pts/3
    short_tty = tty_name.removeprefix("/dev/")
    try:
        result = subprocess.run(
            ["ps", "-t", short_tty, "-o", "pid=,%cpu=,args=",
             "--no-headers", "--sort=-pid"],
            capture_output=True, text=True, timeout=2,
        )
        if result.returncode != 0 or not result.stdout.strip():
            return None
        lines = result.stdout.strip().splitlines()
        if not lines:
            return None
        # Last line = most recently forked process (foreground)
        parts = lines[-1].split(None, 2)
        if len(parts) < 3:
            return None
        pid = int(parts[0])
        cpu = float(parts[1])
        args = parts[2]
        # Sum CPU of all processes on this TTY for total pane usage
        total_cpu = 0.0
        for line in lines:
            p = line.split(None, 2)
            if len(p) >= 2:
                try:
                    total_cpu += float(p[1])
                except ValueError:
                    pass
        return {"pid": pid, "cpu": round(total_cpu, 1), "args": args}
    except (subprocess.TimeoutExpired, OSError, ValueError):
        return None


def process_display_name(foreground_process: str) -> str:
    """Extract a short process name from the full path.

    Handles versioned paths like /path/claude/versions/2.1.62 by
    walking up until we find a non-version-like directory name.
    """
    if not foreground_process:
        return ""
    p = Path(foreground_process)
    name = p.name
    # If the name looks like a version number, walk up to find the real name
    if name and name[0].isdigit():
        for parent in p.parents:
            if parent.name and not parent.name[0].isdigit() and parent.name != "versions":
                return parent.name
    return name


def cmd_enrich() -> int:
    """Read state file, enrich with git/process data, output JSON."""
    if not STATE_FILE.exists():
        json.dump({"tabs": [], "error": "not_running"}, sys.stdout)
        return 0

    try:
        raw = json.loads(STATE_FILE.read_text())
    except (json.JSONDecodeError, OSError):
        json.dump({"tabs": [], "error": "read_error"}, sys.stdout)
        return 0

    tabs = raw.get("tabs", [])

    # Collect unique CWDs for deduplication of git calls
    cwd_map: dict[str, str] = {}  # raw_cwd -> parsed_cwd
    for tab in tabs:
        for pane in tab.get("panes", []):
            parsed = parse_cwd(pane.get("cwd", ""))
            if parsed:
                cwd_map[pane.get("cwd", "")] = parsed

    # Batch git status + project name calls in parallel
    unique_cwds = set(cwd_map.values())
    git_results: dict[str, dict | None] = {}
    project_results: dict[str, str | None] = {}

    with ThreadPoolExecutor(max_workers=4) as pool:
        git_futures = {pool.submit(get_git_status, cwd): cwd for cwd in unique_cwds}
        project_futures = {pool.submit(get_git_root_name, cwd): cwd for cwd in unique_cwds}

        for future in as_completed(list(git_futures) + list(project_futures)):
            if future in git_futures:
                cwd = git_futures[future]
                try:
                    git_results[cwd] = future.result()
                except Exception:
                    git_results[cwd] = None
            else:
                cwd = project_futures[future]
                try:
                    project_results[cwd] = future.result()
                except Exception:
                    project_results[cwd] = None

    # Build enriched output
    enriched_tabs = []
    for tab in tabs:
        enriched_panes = []
        for pane in tab.get("panes", []):
            parsed_cwd = parse_cwd(pane.get("cwd", ""))
            process_name = process_display_name(pane.get("foreground_process", ""))

            proc_info = get_process_info(pane.get("tty_name", ""))

            enriched_panes.append({
                "pane_id": pane.get("pane_id", 0),
                "title": pane.get("title", ""),
                "cwd": parsed_cwd,
                "cwd_short": shorten_path(parsed_cwd),
                "process": process_name,
                "process_args": proc_info["args"] if proc_info else None,
                "cpu": proc_info["cpu"] if proc_info else 0.0,
                "project": project_results.get(parsed_cwd),
                "is_active": pane.get("is_active", False),
                "is_zoomed": pane.get("is_zoomed", False),
                "git": git_results.get(parsed_cwd),
            })

        enriched_tabs.append({
            "tab_id": tab.get("tab_id", 0),
            "tab_title": tab.get("tab_title", ""),
            "is_active": tab.get("is_active", False),
            "panes": enriched_panes,
        })

    output = {
        "workspace": raw.get("workspace", "default"),
        "tabs": enriched_tabs,
    }
    json.dump(output, sys.stdout, separators=(",", ":"))
    return 0


def cmd_activate(pane_id: int) -> int:
    """Focus a pane and raise the WezTerm window."""
    try:
        subprocess.run(
            ["wezterm", "cli", "activate-pane", "--pane-id", str(pane_id)],
            timeout=5,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        print(f"Failed to activate pane {pane_id}", file=sys.stderr)
        return 1

    # Raise WezTerm window in Hyprland
    try:
        subprocess.run(
            ["hyprctl", "dispatch", "focuswindow", "class:org.wezfurlong.wezterm"],
            timeout=2,
        )
    except (subprocess.TimeoutExpired, FileNotFoundError):
        pass  # Non-fatal: pane is activated even if window raise fails

    return 0


def main() -> int:
    parser = JParser(description="WezTerm pane overview for AGS sidebar")
    sub = parser.add_subparsers(dest="command")

    sub.add_parser("enrich", help="Enrich state file with git/process data")

    activate_parser = sub.add_parser("activate", help="Focus a pane")
    activate_parser.add_argument("pane_id", type=int, help="Pane ID to activate")

    args = parser.run()

    if args.command == "enrich":
        return cmd_enrich()
    elif args.command == "activate":
        return cmd_activate(args.pane_id)
    else:
        parser.print_help()
        return 1


if __name__ == "__main__":
    sys.exit(main())
