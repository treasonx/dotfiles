# Zsh cache and history (machine-local, never sync)
.config/zsh/.zcompdump*
.config/zsh/.zsh_history

# Claude Code runtime data (only CLAUDE.md is managed)
.claude/credentials.json
.claude/statsig/
.claude/history*
.claude/debug/
.claude/file-history/
.claude/todos/
.claude/session-env/
.claude/agents/
.claude/skills/
.claude/projects/

# Monitor config (managed by hyprmoncfg, not chezmoi)
.config/hypr/monitors.conf

# Python bytecode cache
.local/bin/__pycache__

# AGS v2 generated files (created by ags init / ags types)
.config/ags/node_modules
.config/ags/@girs

# webview-zone dashboard — desktop only.
{{- if ne .machine "desktop" }}
.config/webview-zone
.local/bin/webview_zone
.local/share/webview-zone
.config/systemd/user/webview-zone.service
{{- end }}

# SDDM greeter theme sources — installed to /usr/share and /etc by
# run_once_install-sddm-noctalia.sh, never deployed to $HOME.
sddm-theme-noctalia
etc
