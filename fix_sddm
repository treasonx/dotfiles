#!/usr/bin/env bash
# fix_sddm — one-stop SDDM installer / repair for the Noctalia greeter.
#
# Idempotent: run on a fresh machine (desktop bootstrap) or any time the
# SDDM setup has drifted (theme breakage, black screen on boot, wrong GPU).
#
# What it does, in order:
#   1.  Install SDDM + Qt6 deps (dnf)
#   2.  Install the dynamic DRM-card wrapper to /usr/local/libexec/sddm-weston
#   3.  Deploy the Noctalia theme to /usr/share/sddm/themes/noctalia
#   4.  Seed /var/lib/sddm-noctalia (shared theme.conf + background)
#   5.  Install /etc/sddm.conf.d/10-noctalia.conf
#   6.  Seed live wallpaper from Noctalia (best-effort)
#   7.  Validate the greeter in --test-mode (mandatory — blocks DM swap)
#   8.  Swap display-manager gdm → sddm (effective next reboot)
#
# Usage:
#   bash ~/dotfiles/fix_sddm              # install / repair, no restart
#   bash ~/dotfiles/fix_sddm --restart    # also restart sddm.service (TTY only)
#
# The --restart flag is refused if a graphical session is detected, because
# restarting SDDM would kill it. From a TTY (Ctrl+Alt+F3), it is safe.
# ---------------------------------------------------------------------------

set -euo pipefail

SOURCE_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
THEME_SRC="${SOURCE_DIR}/sddm-theme-noctalia"
SDDM_CONF_SRC="${SOURCE_DIR}/etc/sddm.conf.d/10-noctalia.conf"
WRAPPER_SRC="${SOURCE_DIR}/sddm-weston"

THEME_DST="/usr/share/sddm/themes/noctalia"
SHARED_DIR="/var/lib/sddm-noctalia"
SHARED_THEME_CONF="${SHARED_DIR}/theme.conf"
SHARED_BG="${SHARED_DIR}/background.png"
WRAPPER_DST="/usr/local/libexec/sddm-weston"

RESTART=0
for arg in "$@"; do
    case "$arg" in
        --restart) RESTART=1 ;;
        -h|--help) sed -n '2,22p' "$0"; exit 0 ;;
        *) printf 'Unknown arg: %s\n' "$arg" >&2; exit 2 ;;
    esac
done

log()  { printf '\e[1;34m==> %s\e[0m\n' "$*"; }
warn() { printf '\e[1;33m!!  %s\e[0m\n' "$*" >&2; }
err()  { printf '\e[1;31mxx  %s\e[0m\n' "$*" >&2; exit 1; }

[[ -d "$THEME_SRC"    ]] || err "Theme source missing: $THEME_SRC"
[[ -f "$SDDM_CONF_SRC" ]] || err "SDDM config missing: $SDDM_CONF_SRC"
[[ -f "$WRAPPER_SRC"   ]] || err "Wrapper missing: $WRAPPER_SRC"

# ---------------------------------------------------------------------------
# 1. Install SDDM + Qt6 deps
# ---------------------------------------------------------------------------
log "Installing SDDM + Qt6 dependencies"
sudo dnf install -y sddm weston qt6-qt5compat qt6-qtdeclarative qt6-qtwayland

# ---------------------------------------------------------------------------
# 2. Install the weston wrapper
#    Lives under /usr/local/libexec because sddm runs as its own system user
#    and needs a world-readable path outside $HOME.
# ---------------------------------------------------------------------------
log "Installing weston wrapper → $WRAPPER_DST"
sudo install -D -m 0755 "$WRAPPER_SRC" "$WRAPPER_DST"

# ---------------------------------------------------------------------------
# 3. Deploy theme files
# ---------------------------------------------------------------------------
log "Deploying theme → ${THEME_DST}"
sudo rsync -a --delete \
    --exclude=".source" \
    --exclude="theme.conf.default" \
    "${THEME_SRC}/" "${THEME_DST}/"

# Sanity-check the Main.qml patch (the displayUser fallback that stops the
# greeter sending an empty username to PAM). If this is missing, we'd ship
# a broken greeter.
if ! grep -q 'avatarRect.displayUser' "${THEME_SRC}/Main.qml"; then
    err "Main.qml is missing the displayUser patch — aborting."
fi

# ---------------------------------------------------------------------------
# 4. Seed the shared dir. james owns the files, sddm reads them via group.
# ---------------------------------------------------------------------------
log "Creating ${SHARED_DIR} (${USER}:sddm 0750)"
sudo install -d -o "$USER" -g sddm -m 0750 "$SHARED_DIR"

if [[ ! -f "$SHARED_THEME_CONF" ]]; then
    log "Seeding ${SHARED_THEME_CONF} from theme default"
    install -m 0644 "${THEME_SRC}/theme.conf.default" "$SHARED_THEME_CONF"
fi

if [[ ! -f "$SHARED_BG" ]]; then
    log "Seeding ${SHARED_BG} from bundled theme asset"
    install -m 0644 "${THEME_SRC}/Assets/background.png" "$SHARED_BG"
fi

# Replace the theme's own theme.conf + background.png with symlinks into the
# shared dir, so live wallpaper updates from the running shell show up on the
# greeter without touching /usr/share.
link_once() {
    local link="$1" target="$2"
    if [[ -L "$link" ]] && [[ "$(readlink "$link")" == "$target" ]]; then
        return 0
    fi
    log "Linking ${link} -> ${target}"
    sudo ln -sfn "$target" "$link"
}
link_once "${THEME_DST}/theme.conf"            "$SHARED_THEME_CONF"
link_once "${THEME_DST}/Assets/background.png" "$SHARED_BG"

# ---------------------------------------------------------------------------
# 5. Install SDDM config snippet
# ---------------------------------------------------------------------------
log "Installing SDDM config → /etc/sddm.conf.d/10-noctalia.conf"
sudo install -D -m 0644 "$SDDM_CONF_SRC" /etc/sddm.conf.d/10-noctalia.conf

# ---------------------------------------------------------------------------
# 6. Seed live wallpaper from Noctalia (best-effort; first boot may not have
#    wallpapers.json yet — the bootstrap asset covers that case).
# ---------------------------------------------------------------------------
if command -v sync_sddm_wallpaper >/dev/null; then
    log "Syncing Noctalia wallpaper → ${SHARED_BG} (best-effort)"
    sync_sddm_wallpaper || warn "sync_sddm_wallpaper failed (non-fatal)"
fi

# ---------------------------------------------------------------------------
# 7. Greeter validation — MANDATORY before swapping the display manager.
#    Judged by log content, not exit code (timeout's SIGTERM produces varied
#    codes; --test-mode always emits a harmless socket error).
# ---------------------------------------------------------------------------
log "Validating greeter in --test-mode (3s)"
TEST_LOG=/tmp/sddm-greeter-test.log
set +e
timeout 3s sddm-greeter-qt6 --test-mode --theme "$THEME_DST" \
    </dev/null >"$TEST_LOG" 2>&1
set -e

show_log()     { sed 's/^/    /' "$TEST_LOG" >&2; }
log_contains() { grep -qiE "$1" "$TEST_LOG"; }

if ! log_contains "Loading .*$(basename "$THEME_DST")/Main\.qml"; then
    warn "Greeter did not load our Main.qml. Log:"
    show_log
    err "Aborting before display-manager swap."
fi
if log_contains 'module .* is not installed|cannot find module|QQmlApplicationEngine failed|QML .* is not a type|file:.*error'; then
    warn "QML errors in greeter log:"
    show_log
    err "Aborting before display-manager swap."
fi
log "Greeter validation passed."

# ---------------------------------------------------------------------------
# 8. Swap display-manager. Takes effect on next reboot — never restart
#    display-manager.service from a graphical session.
# ---------------------------------------------------------------------------
current_dm="$(readlink -f /etc/systemd/system/display-manager.service 2>/dev/null || true)"
if [[ "$current_dm" == *"/sddm.service" ]]; then
    log "SDDM is already the active display-manager."
elif [[ "$current_dm" == *"/gdm.service" ]]; then
    log "Swapping display-manager gdm → sddm (effective next reboot)"
    sudo systemctl disable gdm.service
    sudo systemctl enable sddm.service
else
    warn "Unknown current display-manager: ${current_dm:-none}"
    warn "Enabling sddm; disable any other manager manually if needed."
    sudo systemctl enable sddm.service
fi

# ---------------------------------------------------------------------------
# 9. Optional restart (only from a TTY — never from a graphical session).
# ---------------------------------------------------------------------------
if (( RESTART )); then
    if [[ -n "${WAYLAND_DISPLAY:-}" || -n "${DISPLAY:-}" ]]; then
        err "--restart refused: graphical session detected (WAYLAND_DISPLAY/DISPLAY set). Re-run from a TTY (Ctrl+Alt+F3)."
    fi
    log "Restarting sddm.service"
    sudo systemctl restart sddm
    log "Done. Switch to tty1 (Ctrl+Alt+F1) to see the greeter."
else
    cat <<SUMMARY

$(printf '\e[1;32m✔\e[0m') SDDM + Noctalia theme installed / repaired.

Next steps:
  • Reboot to land on the new greeter:   sudo systemctl reboot
  • Or, from a TTY, restart in place:    bash $0 --restart
  • If the greeter fails to appear:      sddm_rollback   (restores GDM)

SUMMARY
fi
